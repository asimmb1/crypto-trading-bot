# ── Exchange — Live ────────────────────────────────────────────────────────────
BINANCE_API_KEY=your_key_here
BINANCE_SECRET=your_secret_here
BYBIT_API_KEY=your_key_here
BYBIT_SECRET=your_secret_here

# ── Binance Testnet ────────────────────────────────────────────────────────────
BINANCE_TESTNET_API_KEY=your_testnet_key
BINANCE_TESTNET_SECRET=your_testnet_secret

# ── Discord ────────────────────────────────────────────────────────────────────
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/your_webhook_url

# ── Environment ────────────────────────────────────────────────────────────────
ENV=testnet

# ── Grid Bot ───────────────────────────────────────────────────────────────────
GRID_PAIR=BTC/USDT
GRID_TOTAL_CAPITAL=          # Total USDT to allocate (e.g. 100, 300)
GRID_LEVELS=10               # Number of grid levels above + below center
GRID_SPACING_PCT=1.0         # % gap between each level
GRID_STOP_LOSS_PCT=8.0       # % below entry price to cancel grid and stop

# ── DCA Bot ────────────────────────────────────────────────────────────────────
DCA_PAIR=ETH/USDT
DCA_BASE_ORDER=              # USDT size of first buy (e.g. 50)
DCA_SAFETY_ORDER=            # USDT size of each dip buy (e.g. 30)
DCA_MAX_SAFETY_ORDERS=5      # Max dip buys before stopping
DCA_PRICE_DROP_PCT=2.5       # % drop from last buy to trigger next buy
DCA_TAKE_PROFIT_PCT=3.0      # % above avg entry to sell everything
